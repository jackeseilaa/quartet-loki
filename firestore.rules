rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /quartet_journeys/{journeyId} {
      allow read, write: if request.auth != null
        && request.auth.token.email == "jacke.seilaa@gmail.com";
    }

    match /quartet_settings/{settingsId} {
      allow read, write: if request.auth != null
        && request.auth.token.email == "jacke.seilaa@gmail.com";
    }

    match /quartet_fuel_log/{fuelLogId} {
      allow read, write: if request.auth != null
        && request.auth.token.email == "jacke.seilaa@gmail.com";
    }
  }
}
